# ── Backend Environment Variables ──
# Copy this file to .env and fill in values

# JWT Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret-key

# Database
DATABASE_URL=sqlite+aiosqlite:///./its_sql.db

# Google OAuth
GOOGLE_CLIENT_ID=auto-detected-from-firebase

# CORS (frontend URL)
FRONTEND_URL=http://localhost:5173

# Grading Sandbox
SANDBOX_DB_TYPE=sqlite
# If using MySQL sandbox:
# SANDBOX_DB_TYPE=mysql
# SANDBOX_MYSQL_HOST=localhost
# SANDBOX_MYSQL_PORT=3306
# SANDBOX_MYSQL_USER=root
# SANDBOX_MYSQL_PASSWORD=

# Allowed email domain
ALLOWED_EMAIL_DOMAIN=kmitl.ac.th
