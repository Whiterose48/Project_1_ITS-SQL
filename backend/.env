# ── ITS-SQL Backend Environment Variables ──

# JWT Secret Key (auto-generated if blank, but set a fixed one for persistence)
SECRET_KEY=its-sql-dev-secret-key-change-in-production

# Database
DATABASE_URL=sqlite+aiosqlite:///./its_sql.db

# Google OAuth (auto-detected from Firebase config if blank)
GOOGLE_CLIENT_ID=

# CORS (frontend URL)
FRONTEND_URL=http://localhost:8080

# Grading Sandbox
SANDBOX_DB_TYPE=sqlite

# Allowed email domain
ALLOWED_EMAIL_DOMAIN=kmitl.ac.th
